{
  "name": "llm-bridge",
  "version": "1.4.2",
  "description": "LLM bridge service for kguardian - connects frontend to LLM providers",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "keywords": [
    "llm",
    "kubernetes",
    "security",
    "kguardian",
    "ai"
  ],
  "author": "kguardian-dev",
  "license": "BUSL-1.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.113.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "eslint": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.0"
  }
}
